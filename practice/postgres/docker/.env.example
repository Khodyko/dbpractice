POSTGRES_USER=demo
POSTGRES_PASSWORD=demo

# Один PostgreSQL для всех индексных кейсов (idx-01..06)
INDEX_DB=index_demo
INDEX_PORT=5541

# Один PostgreSQL для всех кейсов партиционирования (part-00..03)
PART_DB=part_demo
PART_PORT=5551

# Один Citus-кластер для всех кейсов шардирования
SHARD_DB=shard_demo
SHARD_COORDINATOR_PORT=5560
SHARD_WORKER1_PORT=5561
SHARD_WORKER2_PORT=5562
SHARD_WORKER3_PORT=5563
